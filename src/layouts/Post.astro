---
import Base from "./Base.astro";

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  backHref: string;
  backLabel: string;
}
const { title, date, description, tags = [], backHref, backLabel } = Astro.props;
const dateStr = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={title} description={description}>
  <p style="margin-bottom:1.5rem"><a href={backHref}>← {backLabel}</a></p>
  <h1>{title}</h1>
  <p class="post-meta">
    {dateStr}
    {tags.length > 0 && <span> · {tags.map((t) => <span class="tag">{t}</span>)}</span>}
  </p>
  <article>
    <slot />
  </article>
</Base>
