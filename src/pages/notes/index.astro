---
import Base from "../../layouts/Base.astro";
import SubscribeBox from "../../components/SubscribeBox.astro";
import { SITE } from "../../config";
import { getCollection } from "astro:content";

const notes = (await getCollection("notes"))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Base title={SITE.notesLabel} description="Notes on markets — theses, rationale, post-mortems.">
  <h1>{SITE.notesLabel}</h1>
  <p class="lead">
    Notes on markets — theses, position rationale, and post-mortems. Selected
    notes also go out by email.
  </p>

  <SubscribeBox />

  {notes.length === 0 && <p>Nothing published yet.</p>}

  <ul class="note-list">
    {
      notes.map((n) => (
        <li>
          <a class="note-title" href={`/notes/${n.id}`}>
            {n.data.title}
          </a>
          <div class="note-meta">
            {fmt(n.data.date)}
            {n.data.tags.length > 0 && (
              <span> · {n.data.tags.map((t) => <span class="tag">{t}</span>)}</span>
            )}
            {n.data.description && <div>{n.data.description}</div>}
          </div>
        </li>
      ))
    }
  </ul>
</Base>
