---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const notes = (await getCollection("researchNotes"))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Research Notes" description="Technical write-ups.">
  <h1>Research Notes</h1>
  <p class="lead">Technical write-ups — models, experiments, things I figured out.</p>

  {notes.length === 0 && <p>Nothing published yet.</p>}

  <ul class="note-list">
    {
      notes.map((n) => (
        <li>
          <a class="note-title" href={`/research-notes/${n.id}`}>
            {n.data.title}
          </a>
          <div class="note-meta">
            {n.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
            {n.data.tags.length > 0 && (
              <span> · {n.data.tags.map((t) => <span class="tag">{t}</span>)}</span>
            )}
            {n.data.description && <div>{n.data.description}</div>}
          </div>
        </li>
      ))
    }
  </ul>
</Base>
