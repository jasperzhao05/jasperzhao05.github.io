---
import Base from "../layouts/Base.astro";
import Sidebar from "../components/Sidebar.astro";
import SubscribeBox from "../components/SubscribeBox.astro";
import { SITE } from "../config";
import { getCollection } from "astro:content";

const notes = (await getCollection("notes"))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

// Edit by hand, newest first.
const news = [
  { date: "Jun 2026", text: "Launched this site." },
  { date: "2026", text: "Working toward a workshop submission on visual-token compression." },
];

// Curated — edit freely.
const projects = [
  {
    name: "glassbox",
    desc: "Build modern AI from scratch — LLM internals, RL post-training, and vision, one transparent mechanism per file.",
    href: "https://github.com/jasperzhao05/glassbox",
    tags: [["Python", "tag-blue"], ["from scratch", "tag-purple"]],
  },
  {
    name: "frame2frame",
    desc: "Head-pose estimation from video — Euler angles (yaw/pitch/roll) with FIR signal smoothing.",
    href: "https://github.com/jasperzhao05/frame2frame-virtual-screen",
    tags: [["Python", "tag-blue"], ["computer vision", "tag-green"]],
  },
  {
    name: "ItineralTrace",
    desc: "A multimodal AI travel-planning agent with voice, vision, and memory.",
    href: "https://github.com/jasperzhao05/ItineralTrace-travel-agent",
    tags: [["agents", "tag-amber"], ["multimodal", "tag-purple"]],
  },
];
---

<Base wide showNav={false} description={`${SITE.name} — ${SITE.tagline}`}>
  <div class="layout">
    <Sidebar />

    <div class="content">
      <section id="about">
        <p class="bio">
          I'm a <em>BA in Artificial Intelligence</em> student at CUHK working on
          efficient multimodal models. I study which capabilities of
          vision–language models degrade, and <em>how</em>, when the visual
          tokens they see are compressed. I also write a set of notes on markets.
        </p>
      </section>

      {
        news.length > 0 && (
          <section id="news">
            <h2 class="sec"><span class="dot dot-blue" /> News</h2>
            <ul class="news">
              {news.map((n) => (
                <li>
                  <span class="pill">{n.date}</span>
                  <span>{n.text}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <section id="research">
        <h2 class="sec"><span class="dot dot-purple" /> Research</h2>
        <ul class="rlist">
          <li>Visual-token compression for VLMs — merging, pruning, pooling.</li>
          <li>Capability-specific degradation under a fixed token budget.</li>
          <li>Omission vs. hallucination — and what causes which.</li>
        </ul>
        <p style="margin:0.6rem 0 0;font-size:0.9rem">
          More on the <a href="/research">research page</a>.
        </p>
      </section>

      <section id="projects">
        <h2 class="sec"><span class="dot dot-green" /> Projects</h2>
        <div class="cards">
          {
            projects.map((p) => (
              <a class="card" href={p.href} target="_blank" rel="noopener">
                <div class="card-title">{p.name} ↗</div>
                <p class="card-desc">{p.desc}</p>
                <div class="card-tags">
                  {p.tags.map(([t, cls]) => (
                    <span class={`tag ${cls}`}>{t}</span>
                  ))}
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <section id="notes">
        <h2 class="sec"><span class="dot dot-amber" /> {SITE.notesLabel}</h2>
        <p style="margin:0 0 0.6rem;font-size:0.92rem">
          Notes on markets — theses, position rationale, and post-mortems.
        </p>
        <SubscribeBox />
        {notes.length === 0 && <p style="color:var(--muted)">Nothing published yet.</p>}
        <ul class="nlist">
          {
            notes.slice(0, 5).map((n) => (
              <li>
                <a class="n-title" href={`/notes/${n.id}`}>
                  {n.data.title}
                </a>
                <span class="n-date">{fmt(n.data.date)}</span>
              </li>
            ))
          }
        </ul>
        <a class="more" href="/notes">All {SITE.notesLabel.toLowerCase()} →</a>
      </section>
    </div>
  </div>
</Base>
