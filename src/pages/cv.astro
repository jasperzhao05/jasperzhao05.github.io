  <p class="links-row">
    <a href={`mailto:${SITE.email}`}>Email</a>
    <a href={SITE.github} target="_blank" rel="noopener">GitHub</a>
    <!-- Drop a PDF at public/cv.pdf and this link works. -->
    <a href="/cv.pdf">PDF</a>
  </p>

  <h2>Education</h2>
  <ul class="note-list">
    <li>
      <div class="note-title">B.Sc. in Computer Science <!-- TODO: degree --></div>
      <div class="note-meta">
        <!-- TODO: university · expected graduation · honors / GPA if you want -->
        University · 20XX–20XX
      </div>
    </li>
  </ul>

  <h2>Research experience</h2>
  <ul class="note-list">
    <li>
      <div class="note-title">Efficient multimodal models <!-- TODO --></div>
      <div class="note-meta">
        <!-- TODO: advisor / lab / dates -->
        Compression and failure-mode analysis for vision–language models.
      </div>
    </li>
  </ul>

  <h2>Publications &amp; preprints</h2>
  <p style="color:var(--muted)">
    None yet — work in progress. List them here as
    <em>Authors. Title. Venue, Year.</em> with links once available.
