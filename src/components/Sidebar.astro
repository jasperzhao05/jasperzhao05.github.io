---
import { SITE } from "../config";

const initials = SITE.name
  .split(" ")
  .map((w) => w[0])
  .join("");

// Build the contact links, skipping any that are blank in config.
const links = [
  { label: "Email", href: `mailto:${SITE.email}`, icon: "mail" },
  { label: "CV", href: "/cv", icon: "doc" },
  { label: "GitHub", href: SITE.github, icon: "github", ext: true },
  { label: "Scholar", href: SITE.scholar, icon: "scholar", ext: true },
  { label: "Twitter", href: SITE.twitter, icon: "twitter", ext: true },
  { label: "Substack", href: SITE.substack, icon: "substack", ext: true },
].filter((l) => l.href);

const sections = [
  ["about", "About"],
  ["news", "News"],
  ["research", "Research"],
  ["publications", "Publications"],
  ["projects", "Projects"],
  ["writing", "Writing"],
  ["investing", "Investing"],
];
---

<aside class="sidebar">
  <!-- Swap for a photo: replace this div with
       <img class="headshot" src="/headshot.jpg" alt={SITE.name} /> -->
  <div class="headshot headshot--initials">{initials}</div>
  <h1 class="sb-name">{SITE.name}</h1>
  <p class="sb-role">{SITE.role}{SITE.affiliation && <> · {SITE.affiliation}</>}</p>
  <p class="sb-tag">{SITE.tagline}</p>

  <nav class="sb-nav">
    {sections.map(([id, label]) => <a href={`#${id}`}>{label}</a>)}
  </nav>

  <div class="sb-links">
    {
      links.map((l) => (
        <a
          href={l.href}
          {...(l.ext ? { target: "_blank", rel: "noopener" } : {})}
          aria-label={l.label}
          title={l.label}
        >
          <svg class="ic" viewBox="0 0 24 24" aria-hidden="true">
            {l.icon === "mail" && (
              <path d="M3 5h18v14H3zM3 6l9 7 9-7" fill="none" stroke="currentColor" stroke-width="1.6" />
            )}
            {l.icon === "doc" && (
              <path d="M6 3h8l4 4v14H6zM14 3v4h4M9 13h6M9 17h6" fill="none" stroke="currentColor" stroke-width="1.6" />
            )}
            {l.icon === "github" && (
              <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2z" fill="currentColor" />
            )}
            {l.icon === "scholar" && (
              <path d="M12 3 1 9l11 6 9-4.9V17h2V9zM5 13v4c0 1.7 3.13 3 7 3s7-1.3 7-3v-4l-7 3.8z" fill="currentColor" />
            )}
            {l.icon === "twitter" && (
              <path d="M4 4l6.5 8.5L4.5 20H7l5-5.4L16 20h4l-7-9.1L19.2 4h-2.5l-4.4 4.8L8.4 4z" fill="currentColor" />
            )}
            {l.icon === "substack" && (
              <path d="M4 3h16v3H4zm0 5h16v3H4zm0 5h16v8l-8-4-8 4z" fill="currentColor" />
            )}
          </svg>
        </a>
      ))
    }
  </div>
</aside>
